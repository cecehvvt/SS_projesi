# Supabase Postgres baglanti bilgileri
# Sadece sifreyi ortam degiskeni olarak vermeniz yeterli (asla repoya gercek sifre koymayin).
# Supabase panel -> Project Settings -> Database bolumunden alabilirsiniz.

# Varsayilan baglanti (Connection Pooler, IPv4 - DOGRULANDI, her agda calisir).
# URL ve USER zaten application.properties icinde varsayilan; sadece sifreyi verin:
SUPABASE_DB_PASSWORD=BURAYA_DB_SIFRENIZ

# (Opsiyonel) varsayilani degistirmek isterseniz:
# SUPABASE_DB_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
# SUPABASE_DB_USER=postgres.rqhylrxkbxmvdromdwlt

# Alternatif - Dogrudan baglanti (yalnizca IPv6 destekli aglarda calisir):
# SUPABASE_DB_URL=jdbc:postgresql://db.rqhylrxkbxmvdromdwlt.supabase.co:5432/postgres?sslmode=require
# SUPABASE_DB_USER=postgres
